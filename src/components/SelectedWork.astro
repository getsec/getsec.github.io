---
import { siteConfig } from "../config";
const hasWork = siteConfig.selectedWork && siteConfig.selectedWork.length > 0;
---

{
  hasWork && (
    <section id="work" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Selected Work
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.selectedWork.map((item, index) => (
                <div class="block relative p-4 sm:p-6 md:p-8 bg-gray-50 rounded-xl sm:rounded-2xl border border-gray-200">
                  <div class="space-y-4">
                    <div>
                      <span
                        class="text-sm font-mono"
                        style={{ color: siteConfig.accentColor }}
                      >
                        0{index + 1}
                      </span>
                      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mt-1">
                        {item.name}
                      </h3>
                    </div>

                    <p class="text-base sm:text-lg text-gray-600 leading-relaxed">
                      {item.description}
                    </p>

                    {item.bullets && item.bullets.length > 0 && (
                      <ul class="space-y-2">
                        {item.bullets.map((bullet) => (
                          <li class="flex items-start">
                            <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                            <span class="text-sm sm:text-base text-gray-600">
                              {bullet}
                            </span>
                          </li>
                        ))}
                      </ul>
                    )}

                    {item.skills && item.skills.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                        {item.skills.map((skill) => (
                          <span class="px-2.5 sm:px-3 py-1 sm:py-1.5 bg-gray-900 text-white rounded-md sm:rounded-lg text-xs sm:text-sm font-medium">
                            {skill}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
